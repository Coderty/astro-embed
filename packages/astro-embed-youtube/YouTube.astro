---
import 'lite-youtube-embed/src/lite-yt-embed.css';
import urlMatcher from './matcher';

export interface Props extends astroHTML.JSX.HTMLAttributes {
	id: string;
	poster?: string;
	posterQuality?: 'max' | 'high' | 'default' | 'low';
	params?: string;
	playlabel?: string;
	autoplay?: boolean;
}

const {
	id,
	poster,
	posterQuality = 'default',
	title,
	style,
	autoplay = false,
	params: rawParams = '',
	...attrs
} = Astro.props as Props;

const params = new URLSearchParams(rawParams);
if (autoplay) {
	params.set('mute', '1');
}
const paramsString = params.toString();

const idRegExp = /^[A-Za-z0-9-_]+$/;

function extractID(idOrUrl: string) {
	if (idRegExp.test(idOrUrl)) return idOrUrl;
	return urlMatcher(idOrUrl);
}

const videoid = extractID(id);
const posterFile =
	{
		max: 'maxresdefault',
		high: 'sddefault',
		default: 'hqdefault',
		low: 'default',
	}[posterQuality] || 'hqdefault';
const posterURL =
	poster || `https://i.ytimg.com/vi/${videoid}/${posterFile}.jpg`;
const href = `https://www.youtube.com/watch?v=${videoid}`;

const styles = [];
if (style) styles.push(style);
if (posterURL) styles.push(`background-image: url('${posterURL}')`);
---

<lite-youtube
	{videoid}
	{title}
	data-title={title}
	params={paramsString || undefined}
	data-autoplay={autoplay || undefined}
	{...attrs}
	style={styles.join(';')}
>
	<a {href} class="lyt-playbtn">
		<span class="lyt-visually-hidden">{attrs.playlabel || 'Play'}</span>
	</a>
</lite-youtube>

<script src="lite-youtube-embed"></script>

{autoplay && (
	<script is:inline>
		customElements.whenDefined('lite-youtube').then(function() {
			var observer = new IntersectionObserver(function(entries) {
				entries.forEach(function(entry) {
					if (entry.isIntersecting) {
						/** @type {any} */ (entry.target).activate();
						observer.unobserve(entry.target);
					}
				});
			}, { threshold: 0.5 });
			document.querySelectorAll('lite-youtube[data-autoplay]').forEach(function(el) {
				observer.observe(el);
			});
		});
	</script>
)}

<style is:global>
	lite-youtube.lyt-activated {
		pointer-events: none;
	}
	lite-youtube > iframe {
		all: unset !important;
		width: 100% !important;
		height: 100% !important;
		position: absolute !important;
		inset: 0 !important;
		border: 0 !important;
		pointer-events: auto !important;
	}
</style>
